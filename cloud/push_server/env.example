# Copy to /opt/smarthome-push/.env on the Droplet (chmod 600). Never commit real values.

WEBHOOK_SECRET=generate-a-long-random-string
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...
FCM_PROJECT_ID=your-firebase-project-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...entire JSON on one line...}
FCM_ANDROID_CHANNEL_ID=smarthome_alerts
PUSH_SKIP_EVENT_TYPES=motion_detected
PUSH_MIN_PRIORITY=warning
