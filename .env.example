# ─── Smart Home Pi — Shared .env Configuration ───────────────
# Copy this file to .env and fill in the values.
#
# This is the SINGLE SOURCE OF TRUTH for connection settings.
# Both sh.py (cloud/) and face-recognition/app/ read from here.

# ─── Shared: Backend Connection ──────────────────────────────
API_BASE_URL=http://192.168.1.100:3001
DEVICE_API_KEY=your-device-api-key-here

# ─── Shared: Face-Recognition Resident Sync ─────────────────
SYNC_RESIDENTS_INTERVAL=60

# ─── Cloud: Sensor IDs (UUIDs from backend, set after device registration)
SENSOR_ID_TEMPERATURE=
SENSOR_ID_HUMIDITY=
SENSOR_ID_GAS=
SENSOR_ID_SOIL=

# ─── Cloud: Local buffer directory for offline queue DB ──────
LOCAL_BUFFER_DIR=data

# ─── Cloud: Intervals (seconds) ─────────────────────────────
CLIMATE_INTERVAL_SECONDS=60
HEARTBEAT_INTERVAL_SECONDS=30
SYNC_RETRY_INTERVAL_SECONDS=15

# ─── Cloud: Cooldowns (seconds) ─────────────────────────────
SOIL_ALERT_COOLDOWN_SECONDS=300
GAS_ALERT_COOLDOWN_SECONDS=60

# ─── Cloud: Request settings ────────────────────────────────
REQUEST_TIMEOUT_SECONDS=10
MAX_RETRY_COUNT=10
