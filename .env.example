# ─── Smart Home Pi — Shared .env Configuration ───────────────
# Copy this file to .env and fill in the values.
#
# Root .env is shared by FastAPI gateway (main.py), edge (run_edge.py), and tooling.

# ─── Supabase (gateway writes with service role) ─────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret
SUPABASE_SNAPSHOT_BUCKET=event-snapshots

# ─── Live camera relay (DigitalOcean / production) ───────────
RELAY_URL=wss://relay.yoursmarthome.app
RELAY_ENABLED=true
STREAM_ON_DEMAND=true
RELAY_FPS=15
RELAY_JPEG_QUALITY=60
CAMERA_COLOR_MODE=no_convert

# ─── Face matching (128-D Euclidean; lower distance = closer match) ─
FACE_MATCH_THRESHOLD=0.45
FACE_MATCH_MIN_MARGIN=0.06

# ─── Droplet push_server (.env on /opt/smarthome-push) — never commit ─
# SUPABASE_SERVICE_ROLE_KEY same capability as SUPABASE_SERVICE_KEY (service role JWT).
# WEBHOOK_SECRET must match Supabase Database Webhook header X-Webhook-Secret.
# GOOGLE_SERVICE_ACCOUNT_JSON is the Firebase service account JSON (FCM) as a single line or base64.
# FCM_ANDROID_CHANNEL_ID must match Flutter NotificationService / FCM default channel (default: smarthome_alerts).
# WEBHOOK_SECRET=
# FCM_PROJECT_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON=
# FCM_ANDROID_CHANNEL_ID=smarthome_alerts
# PUSH_SKIP_EVENT_TYPES=motion_detected
# PUSH_MIN_PRIORITY=warning

# Store these only in OCI Application Configuration or OCI Vault; reference secrets from the function.
# OCI Vault: create secrets for WEBHOOK_SECRET, SUPABASE_SERVICE_ROLE_KEY, GOOGLE_SERVICE_ACCOUNT_JSON;
# grant the function's dynamic group read via IAM policy; inject as env vars at deploy time.

# ─── Edge → Gateway (Pi: use Pi LAN IP or localhost if same host) ──
API_BASE_URL=http://127.0.0.1:8000
DEVICE_ID=your-device-uuid-from-devices-table

# ─── Optional: legacy cloud/ HTTP client ─────────────────────
# DEVICE_API_KEY=

# ─── Face-Recognition: pull residents + embedding backfill ─────
SYNC_RESIDENTS_INTERVAL=60
RESIDENT_EMBEDDING_REFRESH_SEC=45

# ─── Cloud: Sensor IDs (UUIDs from backend, set after device registration)
SENSOR_ID_TEMPERATURE=
SENSOR_ID_HUMIDITY=
SENSOR_ID_GAS=
SENSOR_ID_SOIL=

# ─── Cloud: Local buffer directory for offline queue DB ──────
LOCAL_BUFFER_DIR=data

# ─── Cloud: Intervals (seconds) ─────────────────────────────
CLIMATE_INTERVAL_SECONDS=60
HEARTBEAT_INTERVAL_SECONDS=30
SYNC_RETRY_INTERVAL_SECONDS=15

# ─── Cloud: Cooldowns (seconds) ─────────────────────────────
SOIL_ALERT_COOLDOWN_SECONDS=300
GAS_ALERT_COOLDOWN_SECONDS=60

# ─── Cloud: Request settings ────────────────────────────────
REQUEST_TIMEOUT_SECONDS=10
MAX_RETRY_COUNT=10
