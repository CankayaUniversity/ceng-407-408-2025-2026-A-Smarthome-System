# --- Python Standartları ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Sanal Ortamlar (Virtual Environments) ---
.venv/
venv/
env/
ENV/

# --- Çevresel Değişkenler ve Gizli Bilgiler ---
.env

