// Prisma Schema for IoT Smart Home System
// Database: SQLite (can be swapped to PostgreSQL for production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User Authentication ──────────────────────────────────────
model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  name              String
  role              String   @default("resident") // "admin" | "resident"
  notificationsOn   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  devices      Device[]
  alerts       Alert[]
  faceProfiles FaceProfile[]
}

// ─── Device & Sensor Data ─────────────────────────────────────
model Device {
  id        String   @id @default(uuid())
  userId    String
  name      String
  location  String   @default("Home")
  status    String   @default("online") // "online" | "offline"
  apiKey    String   @unique @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sensors      Sensor[]
  alerts       Alert[]
  cameraEvents CameraEvent[]
}

// Sensor types: TEMPERATURE, HUMIDITY, SMOKE, WATER, MOTION, WEIGHT, SOIL_MOISTURE, LIGHT
model Sensor {
  id        String   @id @default(uuid())
  deviceId  String
  type      String   // enum managed at app level
  label     String   @default("")
  unit      String   @default("")
  createdAt DateTime @default(now())

  device   Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  readings SensorReading[]
}

model SensorReading {
  id        String   @id @default(uuid())
  sensorId  String
  value     Float
  createdAt DateTime @default(now())

  sensor Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)
}

// ─── Alerts & Events ──────────────────────────────────────────
// Alert types: FIRE, FLOOD, INTRUSION, LOW_FOOD, LOW_WATER, LOW_MOISTURE, ENERGY_WASTE
model Alert {
  id           String   @id @default(uuid())
  deviceId     String
  userId       String
  type         String
  message      String
  severity     String   @default("warning") // "critical" | "warning" | "info"
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Surveillance Data ────────────────────────────────────────
model CameraEvent {
  id            String   @id @default(uuid())
  deviceId      String
  imagePath     String?  // nullable – Pi may not always attach a photo
  result        String   @default("unknown") // "authorized" | "unauthorized" | "unknown"
  faceProfileId String?
  confidence    Float?
  createdAt     DateTime @default(now())

  device      Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  faceProfile FaceProfile? @relation(fields: [faceProfileId], references: [id])
}

model FaceProfile {
  id        String   @id @default(uuid())
  userId    String
  name      String
  personId  String?  // Pi's local person_id from residents.json (e.g. "res_9938d435")
  imagePath String?
  embedding Json?    // 128-dim face_recognition embedding (stored as JSON array)
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cameraEvents CameraEvent[]
}
